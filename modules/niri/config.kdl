// Pin niri's renderer to the Intel Arc A310 (stable symlink from the intel-gpu
// udev rule). Keeps niri from defaulting to the nvidia GPU, which cannot render
// into the LINEAR buffers the DisplayLink/evdi teleprompter requires.
debug {
    render-drm-device "/dev/dri/intel-render"
}

spawn-at-startup "obs-kiosk"

binds {
  Mod+T { spawn "ghostty"; }
  Mod+B { spawn "librewolf"; }
  Mod+Shift+F { fullscreen-window; }
  Mod+F { maximize-column; }
  Mod+M { maximize-window-to-edges; }
}
