// Broadcast stream-box kiosk: open OBS automatically, maximized.
// `obs-kiosk` is provided by hosts/broadcast/configuration.nix and sets the
// LD_LIBRARY_PATH OBS needs for NVENC before launching.
spawn-at-startup "obs-kiosk"

window-rule {
  match app-id="com.obsproject.Studio"
  open-maximized true
}

binds {
  Mod+T { spawn "ghostty"; }
  Mod+Shift+F { fullscreen-window; }
  Mod+F { maximize-column; }
  Mod+M { maximize-window-to-edges; }
}
